APP_NAME=코트맵
APP_ENV=local
APP_DEBUG=true
APP_URL=https://bad.mvc.kr
APP_TIMEZONE=Asia/Seoul

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=courtmap
DB_USER=courtmap
DB_PASS=

SESSION_NAME=courtmap_session
SESSION_LIFETIME=86400

# Kakao OAuth (1순위 소셜로그인)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://bad.mvc.kr/auth/kakao/callback

# 공휴일은 date.nager.at (무료·키 불필요) 자동 동기화 — 별도 키 없음
